# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# Airtable – base is pre-set to appfdB2W41J5sVZ2U but each coach can override
AIRTABLE_BASE_ID=appfdB2W41J5sVZ2U
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Apify – used to scrape Instagram / LinkedIn profiles
APIFY_API_KEY=apify_api_XXXXXXXXXXXXXXXX

# Calendly – used in reply messages (coaches can also set per-account)
CALENDLY_LINK=https://calendly.com/your-link

# JWT secret – change this to a random 64-char string in production
JWT_SECRET=change-me-to-a-random-secret-string-in-production

# Server
HOST=0.0.0.0
PORT=8000
