{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "ai-lead-gen/backend/Dockerfile",
    "watchPatterns": ["ai-lead-gen/backend/app/**", "ai-lead-gen/backend/requirements.txt"]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
