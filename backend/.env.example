# Claude API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# Model used by the editing agent (brain)
ANTHROPIC_MODEL=claude-opus-4-7

# Whisper model size: tiny, base, small, medium, large
# tiny ≈ 390 MB RAM, base ≈ 1 GB, small ≈ 2.4 GB, medium ≈ 5 GB.
# Default tiny works on a 1 GB dyno. Bump to base/small if you have RAM.
WHISPER_MODEL=tiny

# Storage paths (relative to backend/)
STORAGE_UPLOADS=storage/uploads
STORAGE_OUTPUTS=storage/outputs
STORAGE_WORK=storage/work

# Server
HOST=0.0.0.0
PORT=8000

# Set ACCESS_PASSWORD to a long random string to lock the public site behind
# a password. Leave empty for local-only / unauth dev. ANYONE who knows the
# URL can spend your Anthropic credits if you leave this empty in prod.
ACCESS_PASSWORD=
