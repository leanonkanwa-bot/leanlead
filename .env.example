# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# JWT secret – generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-secret

# ── Optional integrations ─────────────────────────────────────────────────────

# Apify – used to scrape Instagram / TikTok profiles
# (coaches can also provide their own key via the Settings page)
APIFY_API_KEY=apify_api_XXXXXXXXXXXXXXXX

# Airtable – optional CRM sync
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Calendly – default link for reply messages
# (coaches can also set their own via the Settings page)
CALENDLY_LINK=https://calendly.com/your-link
